{
  "name": "@cowasm/py-matplotlib",
  "version": "1.0.0",
  "description": "WebAssembly build of the matplotlib python library",
  "main": "index.js",
  "files": [
    "dist/wasm/**",
    "README.md",
    "package.json",
    "index.js"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "make wasm",
    "prepublishOnly": "pnpm run build && make test",
    "test": "make test"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/sagemathinc/cowasm.git"
  },
  "keywords": [
    "WebAssembly",
    "wasm"
  ],
  "author": "William Stein <wstein@sagemath.com>",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/sagemathinc/cowasm/issues"
  },
  "homepage": "https://github.com/sagemathinc/cowasm/tree/main/python/py-matplotlib",
  "devDependencies": {
    "@cowasm/cpython": "workspace:*",
    "@cowasm/freetype": "workspace:*",
    "@cowasm/kernel": "workspace:*",
    "@cowasm/py-cycler": "workspace:*",
    "@cowasm/py-dateutil": "workspace:*",
    "@cowasm/py-fonttools": "workspace:*",
    "@cowasm/py-numpy": "workspace:*",
    "@cowasm/py-packaging": "workspace:*",
    "@cowasm/py-pip": "workspace:*",
    "@cowasm/py-pyparsing": "workspace:*",
    "@cowasm/py-pytz": "workspace:*",
    "@cowasm/py-six": "workspace:*",
    "@cowasm/qhull": "workspace:*",
    "@cowasm/zlib": "workspace:*"
  }
}
