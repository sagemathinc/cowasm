+
+    p = out;
+    if (negative) {
+        *(p++) = '-';
+    }
+    else if (plus) {
+        *(p++) = '+';
+    }
+    else if (space) {
+        *(p++) = ' ';
+    }
+
+    if (use_exponent) {
+        *(p++) = digits[0];
