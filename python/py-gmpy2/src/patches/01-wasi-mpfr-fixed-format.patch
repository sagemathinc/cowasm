+            p += digits_len - (size_t)exp;
+        }
+        if (alternate) {
+            point = strchr(out, '.');
+            if (!point) {
+                *(p++) = '.';
+                point = p - 1;
+            }
+            while ((p - point - 1) < sig_digits - exp) {
