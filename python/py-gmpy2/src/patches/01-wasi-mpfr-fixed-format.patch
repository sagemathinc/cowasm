+static char *
+GMPy_CoWasm_Append_Long(char *p, long value)
+{
+    char tmp[32];
+    size_t i = 0;
+    unsigned long n;
+
+    if (value < 0) {
+        *(p++) = '-';
+        n = (unsigned long)(-value);
+    }
+    else {
+        n = (unsigned long)value;
+    }
+    do {
+        tmp[i++] = (char)('0' + (n % 10));
+        n /= 10;
+    } while (n != 0);
+    while (i != 0) {
+        *(p++) = tmp[--i];
+    }
+    *p = '\0';
+    return p;
+}
