+            word = (conv == 'F') ? "NAN" : "nan";
+            negative = 0;
+        }
+        else if (mpfr_inf_p(MPFR(self))) {
+            word = (conv == 'F') ? "INF" : "inf";
+        }
+        else {
+            word = "0";
+        }
+
+        out = malloc(strlen(word) + 3);
