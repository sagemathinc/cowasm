+            plus = 1;
+        }
+        else if (*scan == ' ') {
+            space = 1;
+        }
+        else if (*scan == '#') {
+            alternate = 1;
+        }
+        else if (*scan == '.') {
+            precision = strtol(scan + 1, (char **)&scan, 10);
+            continue;
+        }
+        scan++;
+    }
+    if (*scan == 'R') {
+        scan++;
