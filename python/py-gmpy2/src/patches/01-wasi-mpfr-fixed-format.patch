+        p = out;
+        if (negative) {
+            *(p++) = '-';
+        }
+        else if (plus) {
+            *(p++) = '+';
+        }
+        else if (space) {
+            *(p++) = ' ';
+        }
+        strcpy(p, word);
+        result = PyUnicode_FromString(out);
+        free(out);
+        return result;
+    }
+
+    negative = mpfr_signbit(MPFR(self));
+    digits = mpfr_get_str(NULL, &exp_est, 10, 0, MPFR(self), round);
+    if (!digits) {
+        return PyErr_NoMemory();
+    }
+    if (digits[0] == '-') {
+        exp_est--;
+    }
+    mpfr_free_str(digits);
+
+    sig_digits = exp_est > 0 ? exp_est + precision : precision + exp_est;
+    if (sig_digits < 1) {
+        sig_digits = 1;
+    }
+    digits = mpfr_get_str(NULL, &exp, 10, sig_digits, MPFR(self), round);
+    if (!digits) {
+        return PyErr_NoMemory();
+    }
+    if (digits[0] == '-') {
+        negative = 1;
+        memmove(digits, digits + 1, strlen(digits));
+    }
+    digits_len = strlen(digits);
+    out_size = digits_len + (exp > 0 ? (size_t)exp : (size_t)(-exp)) +
+               (size_t)precision + 32;
+    out = malloc(out_size);
+    if (!out) {
+        mpfr_free_str(digits);
+        return PyErr_NoMemory();
+    }
+
+    p = out;
+    if (negative) {
+        *(p++) = '-';
+    }
+    else if (plus) {
+        *(p++) = '+';
+    }
+    else if (space) {
+        *(p++) = ' ';
+    }
+
+    if (exp <= 0) {
+        *(p++) = '0';
+        *(p++) = '.';
+        memset(p, '0', (size_t)(-exp));
+        p += (size_t)(-exp);
+        memcpy(p, digits, digits_len);
+        p += digits_len;
+    }
+    else if ((size_t)exp >= digits_len) {
+        memcpy(p, digits, digits_len);
+        p += digits_len;
+        memset(p, '0', (size_t)exp - digits_len);
+        p += (size_t)exp - digits_len;
+        *(p++) = '.';
+    }
+    else {
+        memcpy(p, digits, (size_t)exp);
+        p += (size_t)exp;
+        *(p++) = '.';
