+static PyObject *
+GMPy_CoWasm_MPFR_Format_Fixed(MPFR_Object *self, const char *mpfrfmt)
+{
+    const char *scan = mpfrfmt + 1;
+    char conv = mpfrfmt[strlen(mpfrfmt) - 1];
+    char *digits = NULL, *out = NULL, *p, *point;
+    mpfr_exp_t exp = 0, exp_est = 0;
