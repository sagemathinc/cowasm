  "devDependencies": {
    "@cowasm/cpython": "workspace:*",
    "@cowasm/gmp": "workspace:*",
    "@cowasm/kernel": "workspace:*",
    "@cowasm/mpc": "workspace:*",
    "@cowasm/mpfr": "workspace:*",
