+static char *
+cowasm_append_signed_exponent(char *p, int value)
+{
+    char tmp[16];
+    int i = 0;
+    unsigned int n;
+
+    if (value < 0) {
+        *p++ = '-';
+        n = (unsigned int)(-value);
+    }
+    else {
+        *p++ = '+';
+        n = (unsigned int)value;
+    }
+
+    do {
+        tmp[i++] = (char)('0' + (n % 10));
+        n /= 10;
+    } while (n != 0);
+    while (i < 2) {
+        tmp[i++] = '0';
+    }
+    while (i != 0) {
+        *p++ = tmp[--i];
+    }
+    return p;
+}
