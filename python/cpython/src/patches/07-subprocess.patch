+extern int python_wasm_fork_exec(char *const exec_array[],
+             char *const argv[],
+             char *const envp[],
+             const char *cwd,
+             int p2cread, int p2cwrite,
+             int c2pread, int c2pwrite,
+             int errread, int errwrite,
+             int errpipe_read, int errpipe_write,
+             int close_fds, int restore_signals,
+             int call_setsid, pid_t pgid_to_set,
+             int call_setgid, gid_t gid,
+             int call_setgroups, size_t groups_size, const gid_t *groups,
+             int call_setuid, uid_t uid, int child_umask,
+             const void *child_sigmask,
+             int *py_fds_to_keep // null or a -1 terminated int[]
+             );
+
+static int *
+cowasm_fds_to_keep_array(PyObject *py_fds_to_keep)
+{
+    Py_ssize_t len = PyTuple_GET_SIZE(py_fds_to_keep);
+    int *fds_to_keep = PyMem_RawMalloc((len + 1) * sizeof(int));
+    if (fds_to_keep == NULL) {
+        errno = ENOMEM;
+        return NULL;
+    }
+    for (Py_ssize_t i = 0; i < len; i++) {
+        PyObject *fdobj = PyTuple_GET_ITEM(py_fds_to_keep, i);
+        fds_to_keep[i] = (int)PyLong_AsLong(fdobj);
+        if (PyErr_Occurred()) {
+            PyMem_RawFree(fds_to_keep);
+            errno = EINVAL;
+            return NULL;
+        }
+    }
+    fds_to_keep[len] = -1;
+    return fds_to_keep;
+}

