+
+static Py_ssize_t
+cowasm_format_uintmax(char *buffer, uintmax_t value, unsigned int base, int uppercase)
+{
+    char tmp[MAX_INTMAX_CHARS];
+    Py_ssize_t len = 0;
+    const char *digits = uppercase ? "0123456789ABCDEF" : "0123456789abcdef";
+
+    assert(base >= 2 && base <= 16);
+    do {
+        tmp[len++] = digits[value % base];
+        value /= base;
+    } while (value != 0);
+
+    for (Py_ssize_t i = 0; i < len; i++) {
+        buffer[i] = tmp[len - i - 1];
+    }
+    buffer[len] = '\0';
+    return len;
+}
+
+static Py_ssize_t
+cowasm_format_intmax(char *buffer, intmax_t value)
+{
+    uintmax_t magnitude;
+    Py_ssize_t len;
+
+    if (value < 0) {
+        buffer[0] = '-';
+        magnitude = (uintmax_t)(-(value + 1)) + 1;
+        len = cowasm_format_uintmax(buffer + 1, magnitude, 10, 0);
+        return len + 1;
+    }
+
+    return cowasm_format_uintmax(buffer, (uintmax_t)value, 10, 0);
+}
+
+static Py_ssize_t
+cowasm_format_signed_arg(char *buffer, int sizemod, va_list *vargs)
+{
+    switch (sizemod) {
+    case F_LONG:
+        return cowasm_format_intmax(buffer, (intmax_t)va_arg(*vargs, long));
+    case F_LONGLONG:
+        return cowasm_format_intmax(buffer, (intmax_t)va_arg(*vargs, long long));
+    case F_SIZE:
+        return cowasm_format_intmax(buffer, (intmax_t)va_arg(*vargs, Py_ssize_t));
+    case F_PTRDIFF:
+        return cowasm_format_intmax(buffer, (intmax_t)va_arg(*vargs, ptrdiff_t));
+    case F_INTMAX:
+        return cowasm_format_intmax(buffer, va_arg(*vargs, intmax_t));
+    default:
+        return cowasm_format_intmax(buffer, (intmax_t)va_arg(*vargs, int));
+    }
+}
+
+static Py_ssize_t
+cowasm_format_unsigned_arg(char *buffer, int sizemod, va_list *vargs,
+                           unsigned int base, int uppercase)
+{
+    switch (sizemod) {
+    case F_LONG:
+        return cowasm_format_uintmax(buffer, (uintmax_t)va_arg(*vargs, unsigned long), base, uppercase);
+    case F_LONGLONG:
+        return cowasm_format_uintmax(buffer, (uintmax_t)va_arg(*vargs, unsigned long long), base, uppercase);
+    case F_SIZE:
+        return cowasm_format_uintmax(buffer, (uintmax_t)va_arg(*vargs, size_t), base, uppercase);
+    case F_PTRDIFF:
+        return cowasm_format_uintmax(buffer, (uintmax_t)va_arg(*vargs, ptrdiff_t), base, uppercase);
+    case F_INTMAX:
+        return cowasm_format_uintmax(buffer, va_arg(*vargs, uintmax_t), base, uppercase);
+    default:
+        return cowasm_format_uintmax(buffer, (uintmax_t)va_arg(*vargs, unsigned int), base, uppercase);
+    }
+}
