{
  "name": "@cowasm/sagelite",
  "version": "1.0.0",
  "description": "Controlled Sagelite build probe for CoWasm Node.js and Electron",
  "type": "module",
  "files": [
    "README.md",
    "bin/*",
    "src/*",
    "package.json",
    "Makefile"
  ],
  "bin": {
    "sage-wasm": "./bin/sage"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "make",
    "clean": "make clean",
    "test": "make test",
    "test:wasi-sdk-standalone": "make test-wasi-sdk-standalone",
    "test:wasi-sdk-next": "make test-wasi-sdk-next"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagemathinc/cowasm.git"
  },
  "homepage": "https://github.com/sagemathinc/cowasm/tree/main/sagemath/sagelite",
  "keywords": ["sagelite", "sagemath", "wasi", "electron"],
  "author": "William Stein",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/sagemathinc/cowasm/issues"
  },
  "dependencies": {
    "@cowasm/conway-polynomials": "workspace:*",
    "@cowasm/cypari2": "workspace:*",
    "@cowasm/cysignals": "workspace:*",
    "@cowasm/memory-allocator": "workspace:*",
    "@cowasm/primecountpy": "workspace:*"
  },
  "devDependencies": {
    "@cowasm/boost-cropped": "workspace:*",
    "@cowasm/cpython": "workspace:*",
    "@cowasm/gmp": "workspace:*",
    "@cowasm/gsl": "workspace:*",
    "@cowasm/libcxx": "workspace:*",
    "@cowasm/libpng": "workspace:*",
    "@cowasm/m4ri": "workspace:*",
    "@cowasm/m4rie": "workspace:*",
    "@cowasm/mpfi": "workspace:*",
    "@cowasm/mpfr": "workspace:*",
    "@cowasm/ntl": "workspace:*",
    "@cowasm/pari": "workspace:*",
    "@cowasm/posix-wasm": "workspace:*",
    "@cowasm/py-cython": "workspace:*",
    "@cowasm/py-gmpy2": "workspace:*",
    "@cowasm/py-jinja2": "workspace:*",
    "@cowasm/py-meson": "workspace:*",
    "@cowasm/py-ninja": "workspace:*",
    "@cowasm/py-numpy": "workspace:*",
    "@cowasm/py-packaging": "workspace:*",
    "@cowasm/py-platformdirs": "workspace:*"
  }
}
