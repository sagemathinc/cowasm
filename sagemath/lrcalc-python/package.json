{
  "name": "@cowasm/lrcalc-python",
  "version": "1.0.0",
  "description": "Python bindings for the Littlewood-Richardson calculator",
  "exports": { "./*": "./dist/js/*.js" },
  "type": "module",
  "files": [
    "dist/js/*",
    "README.md",
    "src/*",
    "package.json",
    "tsconfig.json",
    "Makefile"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "make",
    "clean": "make clean",
    "prepublishOnly": "pnpm run build && make test",
    "test": "make test",
    "test:wasi-sdk-standalone": "make test-wasi-sdk-standalone",
    "test:wasi-sdk-next": "make test-wasi-sdk-next"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagemathinc/cowasm.git"
  },
  "homepage": "https://github.com/sagemathinc/cowasm/tree/main/sagemath/lrcalc-python",
  "keywords": ["littlewood-richardson", "cython", "sagemath"],
  "author": "William Stein",
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/sagemathinc/cowasm/issues"
  },
  "dependencies": {
    "@cowasm/lrcalc": "workspace:*"
  },
  "devDependencies": {
    "@cowasm/cpython": "workspace:*",
    "@cowasm/posix-wasm": "workspace:*",
    "@cowasm/py-cython": "workspace:*"
  }
}
