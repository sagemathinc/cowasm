{
  "name": "@cowasm/saclib",
  "version": "1.0.0",
  "description": "SACLIB real algebraic computation library used by SageMath",
  "exports": { "./*": "./dist/js/*.js" },
  "type": "module",
  "files": [
    "dist/js/*",
    "README.md",
    "src/*",
    "package.json",
    "tsconfig.json",
    "Makefile"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "make",
    "clean": "make clean",
    "prepublishOnly": "pnpm run build && make test",
    "test": "make test",
    "test:wasi-sdk-standalone": "make test-wasi-sdk-standalone"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagemathinc/cowasm.git"
  },
  "homepage": "https://github.com/sagemathinc/cowasm/tree/main/sagemath/saclib",
  "keywords": ["sagemath", "real-algebraic", "computer-algebra"],
  "author": "William Stein",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sagemathinc/cowasm/issues"
  },
  "dependencies": {},
  "devDependencies": {}
}
