--- orig/src/eval.c
+++ mod/src/eval.c
@@ -36,6 +36,12 @@
 #include <signal.h>
 #include <unistd.h>
 #include <sys/types.h>
+#ifdef __cowasm__
+#include <errno.h>
+#include <fcntl.h>
+#include <sys/stat.h>
+#include <string.h>
+#endif
 
 /*
  * Evaluate a command.
@@ -563,6 +569,58 @@
 	pipelen = 0;
 	for (lp = n->npipe.cmdlist ; lp ; lp = lp->next)
 		pipelen++;
+#ifdef __cowasm__
+	{
+		char inpath[] = "/tmp/cowasm-pipe-in-XXXXXX";
+		char outpath[] = "/tmp/cowasm-pipe-out-XXXXXX";
+		char *prevpath = NULL;
+		char *nextpath = outpath;
+		int save0 = -1, save1 = -1;
+		int infd = -1, outfd = -1;
+
+		mkdir("/tmp", 0777);
+
+		for (lp = n->npipe.cmdlist ; lp ; lp = lp->next) {
+			if (prevpath) {
+				infd = open(prevpath, O_RDONLY);
+				if (infd < 0)
+					sh_error("Pipe input open failed: %s", strerror(errno));
+				save0 = savefd(0, 0);
+				dup2(infd, 0);
+				close(infd);
+			}
+			if (lp->next) {
+				outfd = open(nextpath, O_CREAT | O_TRUNC | O_RDWR, 0600);
+				if (outfd < 0)
+					sh_error("Pipe output open failed: %s", strerror(errno));
+				save1 = savefd(1, 1);
+				dup2(outfd, 1);
+				close(outfd);
+			}
+
+			status = evaltree(lp->n, flags & EV_TESTED);
+			flushall();
+
+			if (lp->next) {
+				dup2(save1, 1);
+				close(save1);
+				save1 = -1;
+			}
+			if (prevpath) {
+				dup2(save0, 0);
+				close(save0);
+				unlink(prevpath);
+				save0 = -1;
+			}
+
+			prevpath = lp->next ? nextpath : NULL;
+			nextpath = nextpath == outpath ? inpath : outpath;
+		}
+		if (prevpath)
+			unlink(prevpath);
+		return status;
+	}
+#endif
 	flags |= EV_EXIT;
 	INTOFF;
 	jp = makejob(n, pipelen);
